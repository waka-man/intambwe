---
import '../styles/global.css';
import { asset, absAsset } from '../lib/assets';
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Intambwe — Designing Africa\'s Next Icons',
  description = 'Intambwe is a multidisciplinary creative studio and design house based in Kigali, Rwanda — creating brands, interiors, furniture, lighting and products that blend African creativity with contemporary global design.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href={asset('images/logo-blue.png')} />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0a0a0c" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={absAsset('images/work/alzuri-04.webp')} />
  <meta property="og:url" content={`${absAsset('')}`} />
  <meta name="twitter:card" content="summary_large_image" />
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Instrument+Serif:ital@0;1&family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
    rel="stylesheet"
  />
</head>
<body class="grain">
  <!-- Preloader -->
  <div class="preloader" aria-hidden="true">
    <div class="preloader__word"><span>INTAMBWE</span></div>
  </div>

  <!-- Custom cursor backdrop -->
  <slot />

  <script>
    import '../scripts/main.ts';
  </script>
</body>
</html>
